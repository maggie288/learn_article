NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM（当前仅 MiniMax）
MINIMAX_API_KEY=
# 国内开放平台 Key 必填：MINIMAX_API_BASE=https://api.minimaxi.com（海外留空，默认 api.minimax.io）
MINIMAX_API_BASE=
# Coding Plan 套餐用 MiniMax-M2.5 扣额度；不填默认 MiniMax-M2.5
MINIMAX_MODEL=
OPENAI_API_KEY=

# Auth (email/password via NextAuth)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Stripe (deprecated; use USDT)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# Payments: USDT (TRC20) wallet for subscriptions
USDT_TRC20_WALLET_ADDRESS=

# 促销：设为 true 时所有套餐限时免费，用户选择套餐后点击「免费开通」即可
PROMO_ALL_PLANS_FREE=true

# Async jobs
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# 为 true 时 narrator 步骤发到自建 worker（需单独部署 worker 并加 Sync 端点）
INNGEST_USE_WORKER=
# 生成课程时并行章节数（默认 2，可改为 3–4 加速，注意 MiniMax 限流）
GENERATION_CHAPTER_CONCURRENCY=2

# TTS
ELEVENLABS_API_KEY=

# Cache / rate limit
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Email (Resend: waitlist / notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=PaperFlow <onboarding@yourdomain.com>
LEAD_NOTIFY_EMAIL=

# Optional internal Python engine
ENGINE_PYTHON_URL=

# Sentry (optional; enable in production for error monitoring)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
